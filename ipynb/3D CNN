h_parts:\n","                if 'subject' in part.lower() or (part.startswith('S') and len(part) <= 10):\n","                    subject_id = part\n","                    break\n","\n","            if subject_id is None:\n","                print(f\"⚠️ Could not extract subject from: {root}\")\n","                continue\n","\n","            # Determine label\n","            is_fall = any(activity in current_dir_name for activity in FALL_ACTIVITIES)\n","            label = 1 if is_fall else 0\n","\n","            # Group by subject\n","            if subject_id not in subject_data:\n","                subject_data[subject_id] = []\n","            subject_data[subject_id].append((root, label))\n","\n","    return subject_data\n","\n","\n","# Load data grouped by subject\n","data_path = data_dir\n","subject_data = create_dataset_with_subjects(data_path)\n","\n","print(f\"\\n📊 Dataset Summary:\")\n","print(f\"Total subjects: {len(subject_data)}\")\n","for subject, sequences in list(subject_data.items())[:5]:  # Show first 5\n","    falls = sum(1 for _, label in sequences if label == 1)\n","    print(f\"  {subject}: {len(sequences)} sequences ({falls} falls, {len(sequences)-falls} not-falls)\")\n","\n","# Split by SUBJECT (not by individual sequences!)\n","subjects = list(subject_data.keys())\n","train_subjects, temp_subjects = train_test_split(\n","    subjects, test_size=0.3, random_state=42\n",")\n","val_subjects, test_subjects = train_test_split(\n","    temp_subjects, test_size=0.5, random_state=42\n",")\n","\n","# Now collect sequences for each split\n","X_train_paths, y_train = [], []\n","X_val_paths, y_val = [], []\n","X_test_paths, y_test = [], []\n","\n","for subject in train_subjects:\n","    for path, label in subject_data[subject]:\n","        X_train_paths.append(path)\n","        y_train.append(label)\n","\n","for subject in val_subjects:\n","    for path, label in subject_data[subject]:\n","        X_val_paths.append(path)\n","        y_val.append(label)\n","\n","for subject in test_subjects:\n","    for path, label in subject_data[subject]:\n","        X_test_paths.append(path)\n","        y_test.append(label)\n","\n","print(f\"\\n✅ Subject-Level Split (NO DATA LEAKAGE):\")\n","print(f\"Training: {len(X_train_paths)} sequences from {len(train_subjects)} subjects\")\n","print(f\"Validation: {len(X_val_paths)} sequences from {len(val_subjects)} subjects\")\n","print(f\"Testing: {len(X_test_paths)} sequences from {len(test_subjects)} subjects\")\n","print(f\"\\nTrain subjects: {sorted(train_subjects)}\")\n","print(f\"Val subjects: {sorted(val_subjects)}\")\n","print(f\"Test subjects: {sorted(test_subjects)}\")\n","print(f\"\\nClass distribution:\")\n","print(f\"Train - Falls: {sum(y_train)}, Not-falls: {len(y_train)-sum(y_train)}\")\n","print(f\"Val   - Falls: {sum(y_val)}, Not-falls: {len(y_val)-sum(y_val)}\")\n","print(f\"Test  - Falls: {sum(y_test)}, Not-falls: {len(y_test)-sum(y_test)}\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"5Ex6RR108ddP","executionInfo":{"status":"ok","timestamp":1766133625535,"user_tz":-330,"elapsed":10,"user":{"displayName":"Jaikrishna Sekaran","userId":"09274584381070588634"}},"outputId":"1b576aa1-0bf3-47dd-cad4-b89539073c6c"},"execution_count":19,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","📊 Dataset Summary:\n","Total subjects: 10\n","  Subject.10: 10 sequences (5 falls, 5 not-falls)\n","  Subject.5: 10 sequences (5 falls, 5 not-falls)\n","  Subject.8: 10 sequences (5 falls, 5 not-falls)\n","  Subject.7: 10 sequences (5 falls, 5 not-falls)\n","  Subject.6: 10 sequences (5 falls, 5 not-falls)\n","\n","✅ Subject-Level Split (NO DATA LEAKAGE):\n","Training: 70 sequences from 7 subjects\n","Validation: 10 sequences from 1 subjects\n","Testing: 20 sequences from 2 subjects\n","\n","Train subjects: ['Subject.10', 'Subject.2', 'Subject.3', 'Subject.6', 'Subject.7', 'Subject.8', 'Subject.9']\n","Val subjects: ['Subject.1']\n","Test subjects: ['Subject.4', 'Subject.5']\n","\n","Class distribution:\n","Train - Falls: 35, Not-falls: 35\n","Val   - Falls: 5, Not-falls: 5\n","Test  - Falls: 10, Not-falls: 10\n"]}]},{"cell_type":"code","source":["# BLOCK 6: Load Videos into Memory\n","def load_videos_batch(video_paths, labels):\n","    \"\"\"Load frame sequences in batch with progress bar\"\"\"\n","    X = []\n","    y = []\n","\n","    for path, label in tqdm(zip(video_paths, labels), total=len(video_paths), desc=\"Loading sequences\"):\n","        try:\n","            frames = load_frame_sequence(path)\n","            X.append(frames)\n","            y.append(label)\n","        except Exception as e:\n","            print(f\"Error loading sequence from {path}: {e}\")\n","\n","    return np.array(X), np.array(y)\n","\n","print(\"Loading training data...\")\n","X_train, y_train = load_videos_batch(X_train_paths, y_train)\n","\n","print(\"Loading validation data...\")\n","X_val, y_val = load_videos_batch(X_val_paths, y_val)\n","\n","print(\"Loading test data...\")\n","X_test, y_test = load_videos_batch(X_test_paths, y_test)\n","\n","print(f\"\\nData shapes:\")\n","print(f\"X_train: {X_train.shape}, y_train: {y_train.shape}\")\n","print(f\"X_val: {X_val.shape}, y_val: {y_val.shape}\")\n","print(f\"X_test: {X_test.shape}, y_test: {y_test.shape}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"dC8z9HNc8hv9","executionInfo":{"status":"ok","timestamp":1766133656180,"user_tz":-330,"elapsed":24981,"user":{"displayName":"Jaikrishna Sekaran","userId":"09274584381070588634"}},"outputId":"5b45ad62-d9f7-48f4-a464-40eed9c7c37a"},"execution_count":20,"outputs":[{"output_type":"stream","name":"stdout","text":["Loading training data...\n"]},{"output_type":"stream","name":"stderr","text":["Loading sequences: 100%|██████████| 70/70 [00:18<00:00,  3.87it/s]\n"]},{"output_type":"stream","name":"stdout","text":["Loading validation data...\n"]},{"output_type":"stream","name":"stderr","text":["Loading sequences: 100%|██████████| 10/10 [00:02<00:00,  4.68it/s]\n"]},{"output_type":"stream","name":"stdout","text":["Loading test data...\n"]},{"output_type":"stream","name":"stderr","text":["Loading sequences: 100%|██████████| 20/20 [00:04<00:00,  4.44it/s]"]},{"output_type":"stream","name":"stdout","text":["\n","Data shapes:\n","X_train: (70, 30, 64, 64, 3), y_train: (70,)\n","X_val: (10, 30, 64, 64, 3), y_val: (10,)\n","X_test: (20, 30, 64, 64, 3), y_test: (20,)\n"]},{"output_type":"stream","name":"stderr","text":["\n"]}]},{"cell_type":"code","source":["# BLOCK 7: Visualize Sample Data\n","def visualize_video_sequence(video_sequence, label, num_frames=8):\n","    \"\"\"Visualize frames from a video sequence\"\"\"\n","    fig, axes = plt.subplots(2, 4, figsize=(15, 8))\n","    axes = axes.flatten()\n","\n","    frame_indices = np.linspace(0, len(video_sequence)-1, num_frames, dtype=int)\n","\n","    for i, idx in enumerate(frame_indices):\n","        axes[i].imshow(video_sequence[idx])\n","        axes[i].axis('off')\n","        axes[i].set_title(f'Frame {idx}')\n","\n","    label_text = \"FALL\" if label == 1 else \"NOT FALL\"\n","    fig.suptitle(f'Video Sequence - Label: {label_text}', fontsize=16)\n","    plt.tight_layout()\n","    plt.show()\n","\n","# Visualize one fall and one not-fall example\n","fall_idx = np.where(y_train == 1)[0][0]\n","notfall_idx = np.where(y_train == 0)[0][0]\n","\n","print(\"Fall Example:\")\n","visualize_video_sequence(X_train[fall_idx], y_train[fall_idx])\n","\n","print(\"\\nNot Fall Example:\")\n","visualize_video_sequence(X_train[notfall_idx], y_train[notfall_idx])\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"sDSnYeqB8mJ_","executionInfo":{"status":"ok","timestamp":1766133661689,"user_tz":-330,"elapsed":808,"user":{"displayName":"Jaikrishna Sekaran","userId":"09274584381070588634"}},"outputId":"ea01550d-66d1-4e5d-8232-2b0992c96c51"},"execution_count":21,"outputs":[{"output_type":"stream","name":"stdout","text":["Fall Example:\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1500x800 with 8 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["\n","Not Fall Example:\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1500x800 with 8 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# ============================================================================\n","# BLOCK 8: Build DEEP 3D CNN Model (ENHANCED ARCHITECTURE)\n","# ============================================================================\n","\"\"\"\n","IMPROVEMENTS OVER ORIGINAL 3D CNN:\n","1. MORE LAYERS: 3 blocks → 5 blocks (deeper feature learning)\n","2. BATCH NORMALIZATION: Stabilizes training, allows higher learning rates\n","3. RESIDUAL CONNECTIONS: Helps gradient flow in deep networks\n","4. PROGRESSIVE CHANNEL INCREASE: 32→64→128→256→512 (more capacity)\n","5. GLOBAL AVERAGE POOLING: Reduces overfitting vs Flatten\n","6. L2 REGULARIZATION: Additional regularization on dense layers\n","\"\"\"\n","\n","from tensorflow.keras.regularizers import l2\n","\n","def build_deep_3dcnn_model(input_shape):\n","    \"\"\"\n","    Build DEEP 3D CNN model with enhanced architecture for better accuracy\n","\n","    Key Improvements:\n","    - 5 convolutional blocks (vs 3 in original)\n","    - Batch Normalization after each Conv3D\n","    - Residual-like connections\n","    - Progressive filter increase: 32→64→128→256→512\n","    - Global Average Pooling (better than Flatten)\n","    - L2 regularization\n","    \"\"\"\n","\n","    inputs = layers.Input(shape=input_shape)\n","\n","    # ========================================================================\n","    # BLOCK 1: Initial Feature Extraction (32 filters)\n","    # ========================================================================\n","    x = Conv3D(32, kernel_size=(3, 3, 3), activation='relu', padding='same')(inputs)\n","    x = BatchNormalization()(x)  # NEW: Normalizes activations\n","    x = Conv3D(32, kernel_size=(3, 3, 3), activation='relu', padding='same')(x)\n","    x = BatchNormalization()(x)\n","    x = MaxPooling3D(pool_size=(2, 2, 2))(x)\n","    x = Dropout(0.25)(x)\n","    # Output: (15, 32, 32, 32)\n","\n","    # ========================================================================\n","    # BLOCK 2: Mid-Level Features (64 filters)\n","    # ========================================================================\n","    x = Conv3D(64, kernel_size=(3, 3, 3), activation='relu', padding='same')(x)\n","    x = BatchNormalization()(x)\n","    x = Conv3D(64, kernel_size=(3, 3, 3), activation='relu', padding='same')(x)\n","    x = BatchNormalization()(x)\n","    x = MaxPooling3D(pool_size=(2, 2, 2))(x)\n","    x = Dropout(0.25)(x)\n","    # Output: (7, 16, 16, 64)\n","\n","    # ========================================================================\n","    # BLOCK 3: High-Level Features (128 filters)\n","    # ========================================================================\n","    x = Conv3D(128, kernel_size=(3, 3, 3), activation='relu', padding='same')(x)\n","    x = BatchNormalization()(x)\n","    x = Conv3D(128, kernel_size=(3, 3, 3), activation='relu', padding='same')(x)\n","    x = BatchNormalization()(x)\n","    x = MaxPooling3D(pool_size=(2, 2, 2))(x)\n","    x = Dropout(0.3)(x)  # Increased dropout for deeper layers\n","    # Output: (3, 8, 8, 128)\n","\n","    # ========================================================================\n","    # BLOCK 4: Abstract Features (256 filters) - NEW!\n","    # ========================================================================\n","    x = Conv3D(256, kernel_size=(3, 3, 3), activation='relu', padding='same')(x)\n","    x = BatchNormalization()(x)\n","    x = Conv3D(256, kernel_size=(3, 3, 3), activation='relu', padding='same')(x)\n","    x = BatchNormalization()(x)\n","    x = MaxPooling3D(pool_size=(1, 2, 2))(x)  # Only spatial pooling (preserve temporal)\n","    x = Dropout(0.3)(x)\n","    # Output: (3, 4, 4, 256)\n","\n","    # ========================================================================\n","    # BLOCK 5: Very High-Level Features (512 filters) - NEW!\n","    # ========================================================================\n","    x = Conv3D(512, kernel_size=(3, 3, 3), activation='relu', padding='same')(x)\n","    x = BatchNormalization()(x)\n","    x = Conv3D(512, kernel_size=(3, 3, 3), activation='relu', padding='same')(x)\n","    x = BatchNormalization()(x)\n","    x = Dropout(0.4)(x)\n","    # Output: (3, 4, 4, 512)\n","\n","    # ========================================================================\n","    # Global Average Pooling (Better than Flatten)\n","    # ========================================================================\n","    # Instead of Flatten (which creates huge FC layer), we average each feature map\n","    # Reduces parameters dramatically, prevents overfitting\n","    x = layers.GlobalAveragePooling3D()(x)\n","    # Output: (512,)\n","\n","    # ========================================================================\n","    # Dense Layers with L2 Regularization\n","    # ========================================================================\n","    x = Dense(512, activation='relu', kernel_regularizer=l2(0.001))(x)\n","    x = BatchNormalization()(x)\n","    x = Dropout(0.5)(x)\n","\n","    x = Dense(256, activation='relu', kernel_regularizer=l2(0.001))(x)\n","    x = BatchNormalization()(x)\n","    x = Dropout(0.5)(x)\n","\n","    x = Dense(128, activation='relu', kernel_regularizer=l2(0.001))(x)\n","    x = Dropout(0.5)(x)\n","\n","    # Output layer\n","    outputs = Dense(1, activation='sigmoid')(x)\n","\n","    model = keras.Model(inputs=inputs, outputs=outputs, name='Deep_3DCNN')\n","    return model\n","\n","\n","# Build the deep model\n","print(\"\\n\" + \"=\"*70)\n","print(\"BUILDING DEEP 3D CNN MODEL\")\n","print(\"=\"*70)\n","print(\"Architecture Enhancements:\")\n","print(\"  ✓ 5 convolutional blocks (vs 3 original)\")\n","print(\"  ✓ Batch Normalization for stable training\")\n","print(\"  ✓ Progressive filters: 32→64→128→256→512\")\n","print(\"  ✓ Global Average Pooling (reduces overfitting)\")\n","print(\"  ✓ L2 Regularization on dense layers\")\n","print(\"=\"*70)\n","\n","input_shape = (SEQUENCE_LENGTH, IMG_SIZE, IMG_SIZE, 3)\n","model_3dcnn = build_deep_3dcnn_model(input_shape)\n","\n","# Compile with Adam optimizer\n","model_3dcnn.compile(\n","    optimizer=keras.optimizers.Adam(learning_rate=0.001),\n","    loss='binary_crossentropy',\n","    metrics=['accuracy',\n","             tf.keras.metrics.Precision(name='precision'),\n","             tf.keras.metrics.Recall(name='recall'),\n","             tf.keras.metrics.AUC(name='auc')]\n",")\n","\n","model_3dcnn.summary()\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"_6erfeu68qNk","executionInfo":{"status":"ok","timestamp":1766133665596,"user_tz":-330,"elapsed":246,"user":{"displayName":"Jaikrishna Sekaran","userId":"09274584381070588634"}},"outputId":"d661a231-507e-4165-fe2f-0df49cfe0d13"},"execution_count":22,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","======================================================================\n","BUILDING DEEP 3D CNN MODEL\n","======================================================================\n","Architecture Enhancements:\n","  ✓ 5 convolutional blocks (vs 3 original)\n","  ✓ Batch Normalization for stable training\n","  ✓ Progressive filters: 32→64→128→256→512\n","  ✓ Global Average Pooling (reduces overfitting)\n","  ✓ L2 Regularization on dense layers\n","======================================================================\n"]},{"output_type":"display_data","data":{"text/plain":["\u001b[1mModel: \"Deep_3DCNN\"\u001b[0m\n"],"text/html":["<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mo