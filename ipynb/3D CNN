venly spaced frames\n","    frame_indices = np.linspace(0, total_frames - 1, max_frames, dtype=int)\n","\n","    for idx in frame_indices:\n","        file_path = os.path.join(folder_path, frame_files[idx])\n","        frame = cv2.imread(file_path)\n","\n","        if frame is not None:\n","            frame = cv2.resize(frame, (IMG_SIZE, IMG_SIZE))\n","            frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)\n","            frame = frame / 255.0\n","            frames.append(frame)\n","        else:\n","            print(f\"⚠️  Failed to read: {file_path}\")\n","            if frames:\n","                frames.append(frames[-1])\n","            else:\n","                frames.append(np.zeros((IMG_SIZE, IMG_SIZE, 3)))\n","\n","    # Pad if necessary\n","    while len(frames) < max_frames:\n","        frames.append(frames[-1] if frames else np.zeros((IMG_SIZE, IMG_SIZE, 3)))\n","\n","    return np.array(frames[:max_frames])\n","\n","\n","# ============================================================================\n","# VERIFICATION: Test loading on a few samples\n","# ============================================================================\n","\n","def verify_data_loading(base_path):\n","    \"\"\"\n","    Verify that frame loading is working correctly\n","    \"\"\"\n","    print(\"\\n\" + \"=\"*70)\n","    print(\"VERIFYING DATA LOADING\")\n","    print(\"=\"*70)\n","\n","    test_count = 0\n","    success_count = 0\n","\n","    for root, dirs, files in os.walk(base_path):\n","        # Only check folders with PNG files\n","        png_files = [f for f in files if f.endswith('.png')]\n","\n","        if len(png_files) > 0 and test_count < 5:\n","            activity = os.path.basename(root)\n","            print(f\"\\n📂 Testing: {activity}\")\n","            print(f\"   Path: {root}\")\n","            print(f\"   PNG files found: {len(png_files)}\")\n","            print(f\"   Sample files: {sorted(png_files)[:3]}\")\n","\n","            try:\n","                # Try loading frames\n","                test_sequence = load_frame_sequence(root, max_frames=5)\n","\n","                if test_sequence.shape == (5, IMG_SIZE, IMG_SIZE, 3):\n","                    if test_sequence.max() > 0:  # Check if not all zeros\n","                        print(f\"   ✅ SUCCESS! Loaded shape: {test_sequence.shape}\")\n","                        print(f\"   Value range: [{test_sequence.min():.3f}, {test_sequence.max():.3f}]\")\n","                        print(f\"   Mean value: {test_sequence.mean():.3f}\")\n","                        success_count += 1\n","                    else:\n","                        print(f\"   ⚠️  WARNING: All zeros (black frames)\")\n","                else:\n","                    print(f\"   ❌ ERROR: Wrong shape {test_sequence.shape}\")\n","            except Exception as e:\n","                print(f\"   ❌ ERROR: {e}\")\n","\n","            test_count += 1\n","\n","    print(\"\\n\" + \"=\"*70)\n","    print(f\"✅ Successfully loaded: {success_count}/{test_count} samples\")\n","    print(\"=\"*70)\n","\n","    if success_count == test_count:\n","        print(\"\\n🎉 All samples loaded correctly! Ready to proceed.\")\n","    else:\n","        print(\"\\n⚠️  Some samples failed. Check the errors above.\")\n","\n","# Run verification\n","verify_data_loading(data_dir)\n","\n","\n","# ============================================================================\n","# AFTER VERIFICATION: Re-run Blocks 5, 6, 7\n","# ============================================================================\n","print(\"\\n\" + \"=\"*70)\n","print(\"✅ BLOCK 4 COMPLETE\")\n","print(\"=\"*70)\n","print(\"\\nNext steps:\")\n","print(\"1. Check the verification output above\")\n","print(\"2. If all samples loaded successfully, RE-RUN BLOCKS 5, 6, 7\")\n","print(\"3. Verify visualizations show actual fall/not-fall sequences\")\n","print(\"4. Then train the model!\")\n","print(\"=\"*70)"],"metadata":{"id":"OHysbhL28Ynj","executionIn